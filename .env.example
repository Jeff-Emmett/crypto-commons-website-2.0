# Infisical bootstrap credentials — set as host environment variables (NOT stored in .env)
# Export these in your shell or pass at deploy time:
#   export INFISICAL_CLIENT_ID=xxx INFISICAL_CLIENT_SECRET=yyy
#   docker compose up -d --build
#
# All other secrets (MOLLIE_API_KEY, GOOGLE_SERVICE_ACCOUNT_KEY, GOOGLE_SHEET_ID,
# BOOKING_SHEET_ID, SMTP_PASS, LISTMONK_DB_PASS) are fetched from Infisical at startup.
# Project slug: cofi-register
